{
  "name": "ace-desktop",
  "version": "1.0.0",
  "description": "ACE Desktop Electron launcher",
  "main": "main.js",
  "scripts": {
    "dev": "env -u ELECTRON_RUN_AS_NODE electron .",
    "build:mac": "electron-builder --mac",
    "dist": "electron-builder"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "build": {
    "appId": "ai.acemusic.desktop",
    "productName": "ACE Desktop",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "process-manager.js",
      "preload.js",
      "assets/**/*",
      "package.json"
    ],
    "mac": {
      "icon": "assets/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.music",
      "notarize": true
    }
  },
  "devDependencies": {
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "wait-on": "^9.0.5"
  }
}
