# Optional workspace override (defaults to parent folder of ace-desktop)
# ACE_WORKSPACE_ROOT=/path/to/workspace

# Optional explicit project paths
# ACESTEP_DIR=/path/to/ACE-Step-1.5
# ACE_STEP_UI_DIR=/path/to/ace-step-ui

# Optional ports
# ACE_API_PORT=8001
# ACE_BACKEND_PORT=3001
# ACE_FRONTEND_PORT=3000

# Optional runtime locations
# ACE_LOG_DIR=/path/to/logs
# ACE_RUN_DIR=/path/to/run
